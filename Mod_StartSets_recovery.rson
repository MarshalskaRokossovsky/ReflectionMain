            "Operations": 
            [
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 690,
                    "Parent": -1,
                    "#": 6,
                    "Code.Type": "Global",
                    "Code": 
                    [
                        "GRun();"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 60,
                    "Pos.y": 690,
                    "Parent": -1,
                    "#": 7,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "gov_reward2=0;",
                        "",
                        "dword hull;    int race_hull    = None; int ak_hull    = -1; int mm_hull    = -1; int gtu_hull = 3; int serial_hull = FindSeriesByName(\"Идеал\");",
                        "dword fuel;    int race_fuel    = None; int ak_fuel    = -1; int mm_fuel    = -1; int gtu_fuel = 3;",
                        "dword engine;  int race_engine  = None; int ak_engine  = -1; int mm_engine  = -1; int gtu_engine = 3;",
                        "dword radar;   int race_radar   = None; int ak_radar   = -1; int mm_radar   = -1; int gtu_radar = 3;",
                        "dword scan;    int race_scan    = None; int ak_scan    = -1; int mm_scan    = -1; int gtu_scan = 3;",
                        "dword droid;   int race_droid   = None; int ak_droid   = -1; int mm_droid   = -1; int gtu_droid = 3;",
                        "dword hook;    int race_hook    = None; int ak_hook    = -1; int mm_hook    = -1; int gtu_hook = 3;",
                        "dword def;     int race_def     = None; int ak_def     = -1; int mm_def     = -1; int gtu_def = 3;",
                        "int race_weapon = None;",
                        "",
                        "function give_weapon(type_weap = -1, ak_weap = -1, mm_weap = -1, gtu_weap = 3) {",
                        "    dword weap;",
                        "    if (type_weap>-1) {",
                        "        weap = CreateEquipment(type_weap,20,gtu_weap,race_weapon);",
                        "        if (ak_weap > -1) { SpecialToEquipment(ak_weap,weap); }",
                        "        if (mm_weap > -1) { ModuleToEquipment(mm_weap,weap); }",
                        "        AddItemToStorage(GetShipRuins(Player()), weap);",
                        "    }",
                        "    result=weap;",
                        "}",
                        "",
                        "function set_race(race) {",
                        "    race_hull = race;",
                        "    race_fuel = race;",
                        "    race_engine = race;",
                        "    race_radar = race;",
                        "    race_scan = race;",
                        "    race_droid = race;",
                        "    race_hook = race;",
                        "    race_def = race;",
                        "    race_weapon = race;",
                        "}",
                        "",
                        "function set_race_device(race) {",
                        "    race_fuel = race;",
                        "    race_engine = race;",
                        "    race_radar = race;",
                        "    race_scan = race;",
                        "    race_droid = race;",
                        "    race_hook = race;",
                        "    race_def = race;",
                        "}",
                        "",
                        "function give_mm(bon) {",
                        "    if (bon>-1){",
                        "        dword add_item=CreateMM(bon);",
                        "        AddItemToStorage(GetShipRuins(Player()),add_item);",
                        "    }",
                        "}",
                        "",
                        "function give_art(type) {",
                        "    dword add_item=CreateArt(type,Fei);",
                        "    AddItemToStorage(GetShipRuins(Player()),add_item);",
                        "}",
                        "",
                        "function create() {",
                        "    hull = CreateHull(0,515+buff,gtu_hull,race_hull,serial_hull);",
                        "    fuel = CreateEquipment(t_FuelTanks,20,gtu_fuel,race_fuel);",
                        "    engine = CreateEquipment(t_Engine,20,gtu_engine,race_engine);",
                        "    radar = CreateEquipment(t_Radar,20,gtu_radar,race_radar);",
                        "    scan = CreateEquipment(t_Scaner,20,gtu_scan,race_scan);",
                        "    droid = CreateEquipment(t_RepairRobot,20,gtu_droid,race_droid);",
                        "    hook = CreateEquipment(t_CargoHook,20,gtu_hook,race_hook);",
                        "    def = CreateEquipment(t_DefGenerator,20,gtu_def,race_def);",
                        "}",
                        "",
                        "function give() {",
                        "    AddItemToStorage(GetShipRuins(Player()), hull);",
                        "    AddItemToStorage(GetShipRuins(Player()), fuel);",
                        "    AddItemToStorage(GetShipRuins(Player()), engine);",
                        "    AddItemToStorage(GetShipRuins(Player()), radar);",
                        "    AddItemToStorage(GetShipRuins(Player()), scan);",
                        "    AddItemToStorage(GetShipRuins(Player()), droid);",
                        "    AddItemToStorage(GetShipRuins(Player()), hook);",
                        "    AddItemToStorage(GetShipRuins(Player()), def);",
                        "}",
                        "",
                        "function apply_ak() {",
                        "    if (ak_hull > -1) { SpecialToEquipment(ak_hull,hull); }",
                        "    if (ak_fuel > -1) { SpecialToEquipment(ak_fuel,fuel); }",
                        "    if (ak_engine > -1) { SpecialToEquipment(ak_engine,engine); }",
                        "    if (ak_radar > -1) { SpecialToEquipment(ak_radar,radar); }",
                        "    if (ak_scan > -1) { SpecialToEquipment(ak_scan,scan); }",
                        "    if (ak_droid > -1) { SpecialToEquipment(ak_droid,droid); }",
                        "    if (ak_hook > -1) { SpecialToEquipment(ak_hook,hook); }",
                        "    if (ak_def > -1) { SpecialToEquipment(ak_def,def); }",
                        "}",
                        "",
                        "function apply_mm() {",
                        "    if (mm_hull > -1) { ModuleToEquipment(mm_hull,hull); }",
                        "    if (mm_fuel > -1) { ModuleToEquipment(mm_fuel,fuel); }",
                        "    if (mm_engine > -1) { ModuleToEquipment(mm_engine,engine); }",
                        "    if (mm_radar > -1) { ModuleToEquipment(mm_radar,radar); }",
                        "    if (mm_scan > -1) { ModuleToEquipment(mm_scan,scan); }",
                        "    if (mm_droid > -1) { ModuleToEquipment(mm_droid,droid); }",
                        "    if (mm_hook > -1) { ModuleToEquipment(mm_hook,hook); }",
                        "    if (mm_def > -1) { ModuleToEquipment(mm_def,def); }",
                        "}",
                        "",
                        "function mioplasma() {",
                        "    gtu_engine = 3;",
                        "    mm_engine = FindBonusByName(\"Джейк\");",
                        "    if (race_engine == Maloc) { mm_engine = FindBonusByName(\"Двима\"); }",
                        "    ak_hull = FindBonusByNameInCfg('366');",
                        "    ak_fuel = FindBonusByNameInCfg('373');",
                        "    ak_engine = FindBonusByNameInCfg('374');",
                        "    ak_radar = FindBonusByNameInCfg('375');",
                        "    ak_scan = FindBonusByNameInCfg('376');",
                        "    ak_droid = FindBonusByNameInCfg('377');",
                        "    ak_hook = FindBonusByNameInCfg('378');",
                        "    ak_def = FindBonusByNameInCfg('379');",
                        "}",
                        "",
                        "function pigamar() {",
                        "    gtu_def = 3;",
                        "    gtu_radar = 3;",
                        "    mm_def = FindBonusByName(\"Универс\");",
                        "    if (race_def == Peleng) { mm_def = FindBonusByName(\"Броинг\"); }",
                        "    mm_radar = FindBonusByName(\"Минивизион\");",
                        "    ak_hull = FindBonusByNameInCfg('370');",
                        "    ak_fuel = FindBonusByNameInCfg('394');",
                        "    ak_engine = FindBonusByNameInCfg('395');",
                        "    ak_radar = FindBonusByNameInCfg('396');",
                        "    ak_scan = FindBonusByNameInCfg('397');",
                        "    ak_droid = FindBonusByNameInCfg('398');",
                        "    ak_hook = FindBonusByNameInCfg('399');",
                        "    ak_def = FindBonusByNameInCfg('400');",
                        "}",
                        "",
                        "function transcedent() {",
                        "    ak_engine = FindBonusByNameInCfg('415');",
                        "}",
                        "",
                        "function upgrate() {",
                        "    race_droid = Maloc;",
                        "    ak_fuel = FindBonusByNameInCfg('421');",
                        "    ak_engine = FindBonusByNameInCfg('420');",
                        "    ak_radar = FindBonusByNameInCfg('422');",
                        "    ak_scan = FindBonusByNameInCfg('423');",
                        "    ak_droid = FindBonusByNameInCfg('436'); // biogen droid",
                        "    ak_hook = FindBonusByNameInCfg('418');",
                        "    ak_def = FindBonusByNameInCfg('419');",
                        "}",
                        "",
                        "function ultrasplav() {",
                        "    gtu_engine = 3;",
                        "    mm_engine = FindBonusByName(\"Джейк\");",
                        "    if (race_engine == Maloc) { mm_engine = FindBonusByName(\"Двима\"); }",
                        "    ak_fuel = FindBonusByNameInCfg('450');",
                        "    ak_radar = FindBonusByNameInCfg('449');",
                        "    ak_scan = FindBonusByNameInCfg('448');",
                        "    ak_hook = FindBonusByNameInCfg('451');",
                        "    ak_droid = FindBonusByNameInCfg('436'); // biogen droid",
                        "}",
                        "",
                        "function nanobrolit() {",
                        "    ak_engine = FindBonusByNameInCfg('440');",
                        "    ak_droid = FindBonusByNameInCfg('439');",
                        "    ak_def = FindBonusByNameInCfg('441');",
                        "}",
                        "",
                        "function oskolok() {",
                        "    give_weapon(t_Weapon2, FindBonusByNameInCfg('502'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function esodafer() {",
                        "    give_weapon(t_Weapon16, FindBonusByNameInCfg('537'), FindBonusByName(\"Универс\")); //заменить на мм с баффом на урон + заменить на эсодафер",
                        "}",
                        "",
                        "function missile() {",
                        "    int module = FindBonusByName(\"Антифэй\");",
                        "    if (race_weapon == Fei || race_weapon == PirateClan) module = FindBonusByName(\"Универс\");",
                        "    give_weapon(t_Weapon4, FindBonusByNameInCfg('511'), module);",
                        "}",
                        "",
                        "function leska() {",
                        "    give_weapon(t_Weapon3, FindBonusByNameInCfg('507'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function kafasitor() {",
                        "    give_weapon(t_Weapon17, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function treton() {",
                        "    if (race_weapon == PirateClan) {",
                        "        give_weapon(t_Weapon5, FindBonusByNameInCfg('515'), FindBonusByName(\"Дальпун\"), 7);",
                        "    } else {",
                        "        give_weapon(t_Weapon5, FindBonusByNameInCfg('514'), FindBonusByName(\"Дальпун\"), 7);",
                        "    }",
                        "}",
                        "",
                        "function rezak() {",
                        "    give_weapon(t_Weapon8, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\")); //заменить мм (возможно) и акрин",
                        "}",
                        "",
                        "function multirez() {",
                        "    give_weapon(t_Weapon9, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\")); //заменить мм (возможно) и акрин",
                        "}",
                        "",
                        "function resolve() {",
                        "    ShipMoney(Player(),ShipMoney(Player())+85000);",
                        "    gov_reward2=1;",
                        "}",
                        "",
                        "function stimulate(stimul) {",
                        "    ShipHealthFactor(Player(),stimul,120);",
                        "}",
                        "",
                        "function buster(){",
                        "    dword art =CreateCustomArt('Booster',10,10000,Rnd(0,4));",
                        "\tAddItemToShip(Player(),art);",
                        "}",
                        "",
                        "function reflector(){",
                        "    dword art =CreateCustomArt('Reflector',10,10000,Rnd(0,4));",
                        "\tAddItemToShip(Player(),art);",
                        "}",
                        "",
                        "function texdistr(){",
                        "    dword art =CreateCustomArt('Techdisruptor',10,10000,Rnd(0,4));",
                        "\tAddItemToShip(Player(),art);",
                        "}",
                        "",
                        "function hasker(){",
                        "    dword art =CreateCustomArt('Hasker_PROx64',10,10000,Rnd(0,4));",
                        "\tAddItemToShip(Player(),art);",
                        "}",
                        "",
                        "function nullgen(){",
                        "\tdword tdwd=CreateQuestItem('Null-generator');",
                        "\tItemSize(tdwd,1);",
                        "\tItemCost(tdwd,1000);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "",
                        "function bombogl(){",
                        "\tdword tdwd=CreateQuestItem('Stun_bomb');",
                        "\tItemSize(tdwd,1);",
                        "\tItemCost(tdwd,1000);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "",
                        "function bombemp(){",
                        "    dword tdwd=CreateQuestItem('EMP_bomb');",
                        "\tItemSize(tdwd,1);",
                        "\tItemCost(tdwd,1000);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "",
                        "function bombneitron(){",
                        "    dword tdwd=CreateQuestItem('NeutronBomb');",
                        "\tItemSize(tdwd,1);",
                        "\tItemCost(tdwd,1000);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "",
                        "function detonator(){",
                        "    dword tdwd=CreateQuestItem('BombDetonator');",
                        "\tItemSize(tdwd,1);",
                        "\tItemCost(tdwd,1000);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "",
                        "function turbik() {",
                        "    give_weapon(t_Weapon12, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function laser() {",
                        "    give_weapon(t_Weapon1, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function blaster() {",
                        "    give_weapon(t_Weapon7, FindBonusByNameInCfg('540'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function lirekron() {",
                        "    give_weapon(t_Weapon18, FindBonusByNameInCfg('543'), FindBonusByName(\"Универс\"));",
                        "}",
                        "",
                        "function tovar() {",
                        "    GoodsAdd(Player(),t_Food,200);",
                        "    GoodsAdd(Player(),t_Medicine,200);",
                        "    GoodsAdd(Player(),t_Technics,100);",
                        "    GoodsAdd(Player(),t_Luxury,50);",
                        "    GoodsAdd(Player(),t_Alcohol,100);",
                        "}",
                        "",
                        "function contra() {",
                        "    GoodsAdd(Player(),t_Luxury,70);",
                        "    GoodsAdd(Player(),t_Alcohol,180);",
                        "    GoodsAdd(Player(),t_Arms,75);",
                        "    GoodsAdd(Player(),t_Narcotics,50);",
                        "}"
                    ]
